# ===========================================
# TempChat - Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control!

# ===========================================
# DATABASE - Neon PostgreSQL
# ===========================================
# Get your connection string from: https://neon.tech
# → Dashboard → Project → Connection Details
# 
# Format: postgresql://username:password@host/database?sslmode=require

DATABASE_URL="postgresql://username:password@ep-xxx.region.aws.neon.tech/tempchat?sslmode=require"

# ===========================================
# CLOUDFLARE R2 - File Storage
# ===========================================
# Get credentials from: https://dash.cloudflare.com
# → R2 Object Storage → Manage R2 API Tokens
#
# ACCOUNT_ID: Found in Cloudflare Dashboard URL
# R2_BUCKET_NAME: The name you gave your bucket
# R2_PUBLIC_URL: Your bucket's public URL (e.g., https://pub-xxx.r2.dev)

R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="tempchat-files"
R2_PUBLIC_URL="https://pub-xxx.r2.dev"

# ===========================================
# APPLICATION
# ===========================================

# Your app's public URL (used for CORS and links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================================
# OPTIONAL - Analytics
# ===========================================

# Add your analytics provider if needed
# NEXT_PUBLIC_ANALYTICS_ID=""
